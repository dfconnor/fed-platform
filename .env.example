# ============================================
# Fed Platform — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.

# --- NextAuth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# --- Auth Enforcement ---
# Set to "true" to require login in development (default: bypassed for demo)
# Always enforced in production regardless of this setting.
# ENFORCE_AUTH=true

# --- Google OAuth (optional for dev) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Stripe (optional, demo mode works without) ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Database ---
# Default SQLite (no config needed for dev)
# For Turso/LibSQL production:
# DATABASE_URL=libsql://your-db.turso.io
# DATABASE_AUTH_TOKEN=your-token
